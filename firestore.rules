rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Storico e calendario: solo il proprietario autenticato può leggere/scrivere
    // i propri documenti in users/{uid}/data/{history|calendario}.
    // Vedi pronostick_sicurezza.md, invariante #5.
    match /users/{uid}/data/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Tutto il resto: negato di default (nessun accesso implicito).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
